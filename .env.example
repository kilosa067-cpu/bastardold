# ============================================
# BASTARD OLD SCHOOL MASTER BARBER
# Variables de Entorno - FIREBASE
# ============================================

# --------------------------------------------
# FIREBASE CONFIGURATION (Obligatorio para Firebase)
# --------------------------------------------
# 1. Ve a https://console.firebase.google.com/
# 2. Crea un proyecto nuevo
# 3. Ve a Configuración del proyecto > General
# 4. Copia los valores de "Configuración de SDK"

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# --------------------------------------------
# ADMIN CREDENTIALS (Para login del admin)
# --------------------------------------------
# Crea un usuario en Firebase Auth > Users
VITE_ADMIN_EMAIL=admin@bastard.com
VITE_ADMIN_PASSWORD=tu_password_seguro

# --------------------------------------------
# PAYPAL (Opcional - Para pagos reales)
# --------------------------------------------
VITE_PAYPAL_CLIENT_ID=tu_client_id_de_paypal

# --------------------------------------------
# ZOHO MAIL SMTP (Para enviar emails)
# --------------------------------------------
# 1. Crea cuenta en https://www.zoho.com/mail/
# 2. Configura tu dominio bastardoldschool.com.mx
# 3. Ve a Configuración > Cuentas > SMTP
# 4. Activa "Acceso IMAP" y genera contraseña de aplicación
# 5. Copia los datos aquí:

SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=citas@bastardoldschool.com.mx
SMTP_PASS=tu_contraseña_de_aplicación_zoho

# --------------------------------------------
# NOTAS:
# --------------------------------------------
# - Copia este archivo a .env y rellena los valores
# - Nunca subas el archivo .env a GitHub
# - Las variables VITE_ son accesibles desde el frontend
# ============================================
